# === FireWatch AI Backend — Environment Variables ===

# Path to the MobileNet .h5 model file (relative to backend/ or absolute)
MODEL_PATH=../MobileNet_model.h5

# Database URL
# Default (SQLite — zero config, works out of the box):
DATABASE_URL=sqlite+aiosqlite:///./firewatch.db
# To switch to PostgreSQL/Supabase, uncomment and set:
# DATABASE_URL=postgresql+asyncpg://user:password@host:5432/firewatch

# Directory for uploaded images (relative to backend/)
UPLOAD_DIR=./uploads

# Confidence threshold for promoting "High" → "Critical"
# Model predicts High with confidence >= this value → labeled Critical
CRITICAL_CONFIDENCE_THRESHOLD=0.90

# CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:8081,http://localhost:19006
